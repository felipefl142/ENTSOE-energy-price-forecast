# ENTSO-E API — register at https://transparency.entsoe.eu/
# Free API token: create account, then request token via My Account Settings
ENTSOE_API_KEY=your_entsoe_api_key_here

# Open-Meteo — no key required (free tier, no registration)
# OPENMETEO_BASE_URL=https://archive-api.open-meteo.com/v1/archive

# ZenML (local open source — no external service needed)
# Start dashboard with: zenml up
ZENML_DASHBOARD_URL=http://127.0.0.1:8237

# FastAPI
API_HOST=0.0.0.0
API_PORT=8000
